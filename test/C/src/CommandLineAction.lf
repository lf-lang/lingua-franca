target C {
  fast: true
}

main reactor(min_delay: time = 1 ns, min_spacing: time = 10 ns) {
  logical action a(min_delay, min_spacing)
  timer t(0, 1 ns)
  state count: int = 0

  reaction(t) -> a {=
    lf_schedule(a, 0);
  =}

  reaction(a) {=
    interval_t elapsed = lf_time_logical_elapsed();
    lf_print("Elapsed: " PRINTF_TIME ".\n", elapsed);
    interval_t expected = self->count++ * self->min_spacing + self->min_delay;
    if (elapsed != expected) {
      lf_print_error_and_exit("Expected " PRINTF_TIME " but got " PRINTF_TIME, expected, elapsed);
    }
    if (self->count == 10) {
      lf_request_stop();
    }
  =}

  reaction(shutdown) {=
    if (self->count != 10) {
      lf_print_error_and_exit("Expected 10 events but got %d", self->count);
    }
    lf_print("Test passed.\n");
  =}
}
