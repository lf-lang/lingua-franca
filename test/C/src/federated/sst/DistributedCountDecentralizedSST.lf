/**
 * Test a simple federated system using SST (Secure Swarm Toolkit) for secure communication in a
 * decentralized coordination setting.
 *
 * To run this test, you must specify the path to your local SST repository. You can do this by
 * either: 1. Setting the `sst-root-path` target property in the `sst` dictionary. 2. Setting the
 * `SST_ROOT` environment variable in your system.
 *
 * Based on the DistributedCountDecentralized test.
 *
 * @author Edward A. Lee
 * @author Dongha Kim
 */
target C {
  timeout: 5 sec,
  coordination: decentralized,
  comm-type: SST,
  clock-sync: on,
  clock-sync-options: {
    local-federates-on: true
  }
}

import Count from "../../lib/Count.lf"

import Print from "../DistributedCountDecentralized.lf"

federated reactor DistributedCountDecentralizedSST {
  c = new Count()
  p = new Print()
  c.out -> p.in after 200 msec  // Indicating a 'logical' connection with a large enough delay.
}
