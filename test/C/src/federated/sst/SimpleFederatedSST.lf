/**
 * Test a simple federated system using SST (Secure Swarm Toolkit) for secure communication.
 * 
 * To run this test, you must specify the path to your local SST repository.
 * You can do this by either:
 * 1. Setting the `sst-root-path` target property in the `sst` dictionary.
 * 2. Setting the `SST_ROOT` environment variable in your system.
 * 
 * @author Dongha Kim
 */
target C {
  timeout: 2 secs,
  comm-type: SST
}

reactor Fed {
  input in: int
  output out: int
}

federated reactor {
  fed1 = new Fed()
  fed2 = new Fed()

  fed1.out -> fed2.in
  fed2.out -> fed1.in
}
