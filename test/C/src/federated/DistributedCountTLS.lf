/**
 * A simple federated Lingua Franca program to test TLS-based secure communication. This test
 * verifies that the RTI and federates can successfully establish TLS connections using the
 * automatically generated certificates and keys.
 *
 * Based on the DistributedCount test.
 *
 * @author Edward A. Lee
 * @author Dongha Kim
 */
target C {
  timeout: 5 sec,
  coordination: centralized,
  comm-type: TLS
}

import Count from "../lib/Count.lf"
import Print from "DistributedCount.lf"

federated reactor DistributedCountTLS(offset: time = 200 msec) {
  c = new Count()
  p = new Print()
  c.out -> p.in after offset
}
