/**
 * A Polyglot federated version of DistributedCount using decentralized coordination, with a Python
 * sender and a C receiver. The PythonProtoCount federate (Python) emits an incrementing count
 * carried in a ProtoHelloWorld message; the CProtoCountPrint federate (C) receives it over a
 * federated connection with serializer "proto". The logical delay on the connection is large enough
 * that each message is safe to process at its intended tag without any additional time
 * coordination.
 *
 * <p>A common protobuf serializer is required for cross-language federated connections: C uses raw
 * bytes and Python uses pickle for native serialization, so the two cannot exchange native values
 * directly.
 *
 * <p>To run this test, install protoc, protoc-c, libprotobuf-c, and the Python protobuf package
 * (pip install protobuf).
 *
 * @author Hokeun Kim
 */
target Polyglot {
  protobufs: [ProtoHelloWorld.proto],
  timeout: 5 sec,
  coordination: decentralized
}

import PythonProtoCount from "../lib/PythonProtoCount.lf"
import CProtoCountPrint from "../lib/CProtoCount.lf"

federated reactor {
  c = new PythonProtoCount()
  p = new CProtoCountPrint()

  // Indicating a 'logical' connection with a large enough delay.
  c.out -> p.in after 200 msec serializer "proto"
}
