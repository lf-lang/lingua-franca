/**
 * A Polyglot federated version of DistributedCount with a C sender and a Python receiver. The
 * CProtoCount federate (C) emits an incrementing count carried in a ProtoHelloWorld message; the
 * PythonProtoCountPrint federate (Python) receives it over a federated connection with serializer
 * "proto" and checks both the value and the logical tag at which it arrives. Because the connection
 * has a logical delay, this is a simple distributed deterministic system that needs no additional
 * coordination of the advancement of time.
 *
 * <p>A common protobuf serializer is required for cross-language federated connections: C uses raw
 * bytes and Python uses pickle for native serialization, so the two cannot exchange native values
 * directly.
 *
 * <p>To run this test, install protoc, protoc-c, libprotobuf-c, and the Python protobuf package
 * (pip install protobuf).
 *
 * @author Hokeun Kim
 */
target Polyglot {
  protobufs: [ProtoHelloWorld.proto],
  timeout: 5 sec,
  coordination: centralized
}

import CProtoCount from "../lib/CProtoCount.lf"
import PythonProtoCountPrint from "../lib/PythonProtoCount.lf"

federated reactor {
  c = new CProtoCount()
  p = new PythonProtoCountPrint()

  c.out -> p.inp after 200 msec serializer "proto"
}
