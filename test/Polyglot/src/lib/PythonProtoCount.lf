/**
 * Library reactors for a Python-side protobuf Count sender and Print receiver, intended to be
 * imported by Polyglot federated programs. PythonProtoCount sends an incrementing count carried in
 * the {@code number} field of a ProtoHelloWorld message; PythonProtoCountPrint receives the message,
 * validates the count, and checks that each message arrives at its expected logical tag. Proto
 * bindings are generated by the importing program's {@code protobufs} target property.
 *
 * @author Hokeun Kim
 */
target Python

reactor PythonProtoCount(offset=0, period = 1 sec) {
  output out

  state count = 1

  timer t(offset, period)

  reaction(t) -> out {=
    msg = ProtoHelloWorld.ProtoHelloWorld()
    msg.name = "Count"
    msg.number = self.count
    out.set(msg)
    self.count += 1
  =}
}

reactor PythonProtoCountPrint {
  input inp

  state c = 1

  reaction(inp) {=
    elapsed_time = lf.time.logical_elapsed()
    print(f"At time {elapsed_time}, received {inp.value.number}.")
    if inp.value.number != self.c:
      sys.stderr.write("Expected to receive {}.\n".format(self.c))
      sys.exit(1)
    if elapsed_time != MSEC(200) + SEC(1) * (self.c - 1):
      sys.stderr.write("Expected received time to be {}.\n".format(MSEC(200) + SEC(1) * (self.c - 1)))
      sys.exit(3)
    self.c += 1
  =}

  reaction(shutdown) {=
    if self.c != 6:
      sys.stderr.write("Expected to receive 5 items.\n")
      sys.exit(2)
    print("SUCCESS: Successfully received 5 items.")
  =}
}
