/**
 * Library reactors for a C-side protobuf Count sender and Print receiver, intended to be imported by
 * Polyglot federated programs. CProtoCount sends an incrementing count carried in the {@code number}
 * field of a ProtoHelloWorld message; CProtoCountPrint receives the message, validates the count, and
 * checks that each message arrives at its expected logical tag. Proto bindings are generated by the
 * importing program's {@code protobufs} target property.
 *
 * @author Hokeun Kim
 */
target C

reactor CProtoCount(offset: time = 0, period: time = 1 sec) {
  output out: ProtoHelloWorld*

  state count: int = 1

  timer t(offset, period)

  reaction(t) -> out {=
    ProtoHelloWorld* msg = (ProtoHelloWorld*)malloc(sizeof(ProtoHelloWorld));
    proto_hello_world__init(msg);
    msg->name = "Count";
    msg->number = self->count++;
    lf_set(out, msg);
  =}
}

reactor CProtoCountPrint {
  input in: ProtoHelloWorld*

  state c: int = 1

  reaction(in) {=
    interval_t elapsed_time = lf_time_logical_elapsed();
    lf_print("At time " PRINTF_TIME ", received %d.", elapsed_time, in->value->number);
    if (in->value->number != self->c) {
      lf_print_error_and_exit("Expected to receive %d.", self->c);
    }
    if (elapsed_time != MSEC(200) + SEC(1) * (self->c - 1)) {
      lf_print_error_and_exit(
        "Expected received time to be " PRINTF_TIME ".",
        MSEC(200) + SEC(1) * (self->c - 1)
      );
    }
    self->c++;
  =}

  reaction(shutdown) {=
    if (self->c != 6) {
      lf_print_error_and_exit("Expected to receive 5 items. Received %d.", self->c - 1);
    }
    lf_print("SUCCESS: Successfully received 5 items.");
  =}
}
