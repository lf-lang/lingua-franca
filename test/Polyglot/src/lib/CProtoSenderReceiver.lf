/**
 * Library reactors for C-side protobuf sender and receiver, intended to be imported by Polyglot
 * federated programs. The CSender reactor sends a ProtoHelloWorld message on a typed output port;
 * the CReceiver reactor receives and validates it. Proto bindings are generated by the importing
 * program's target block.
 *
 * @author Hokeun Kim
 */
target C

reactor CSender {
  output out: ProtoHelloWorld*

  state count: int = 0

  timer t(0, 1 sec)

  reaction(t) -> out {=
    self->count++;
    ProtoHelloWorld* msg = (ProtoHelloWorld*)malloc(sizeof(ProtoHelloWorld));
    proto_hello_world__init(msg);
    msg->name = "Hello World";
    msg->number = self->count;
    lf_set(out, msg);
  =}
}

reactor CReceiver {
  input in: ProtoHelloWorld*

  state count: int = 0

  reaction(in) {=
    lf_print(
      "Received: name=\"%s\", number=%d.",
      in->value->name,
      in->value->number
    );
    if (in->value->number != self->count + 1) {
      lf_print_error_and_exit("Expected number %d.", self->count + 1);
    }
    self->count++;
  =}
}
