target Rust

reactor Parent(a: i32 = 0) {
  state a = a
}

reactor T(b: i32 = 0) {
  state b = b
  output out: i32

  reaction(startup) -> out {=
    println!("b: {}", self.b);
    ctx.set(out, self.b);
  =}
}

reactor Child extends Parent {
  output out: i32
  t = new T(b=a)
  t.out -> out
}

main reactor {
  c1 = new Child(a=42)

  reaction(c1.out) {=
    println!("c1.out: {}", ctx.get(c1__out).unwrap());
    if ctx.get(c1__out).unwrap() != 42 {
      eprintln!("Expected 42");
      ctx.request_stop(Asap);
    }
  =}
}
