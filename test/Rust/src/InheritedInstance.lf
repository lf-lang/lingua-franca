target Rust

reactor Foo {
  input in: u32
  output out: u32

  reaction(in) -> out {=
    // r#in is a special variable for rust as `in` is a keyword in Rust
    ctx.set(out, ctx.get(r#in).unwrap());
  =}
}

reactor Blank {
  reaction(startup) {=
    println!("does nothing");
  =}
}

reactor Parent {
  input in: u32
  output out: u32
  f = new Foo()
}

reactor Child extends Parent {
  reaction(startup) -> f.in {=
    ctx.set(f__in, 42);
  =}

  reaction(f.out) {=
    println!("Out: {}", ctx.get(f__out).unwrap());
    if ctx.get(f__out).unwrap() != 42 {
        eprintln!("Expected 42");
        ctx.request_stop(Asap);
    }
  =}
}

main reactor {
  c = new Child()
}
