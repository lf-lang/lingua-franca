target Rust

reactor Foo {
  input inp: u32
  output out: u32

  reaction(inp) -> out {=
    ctx.set(out, ctx.get(inp).unwrap());
  =}
}

reactor Blank {
  reaction(startup) {=
    println!("does nothing");
  =}
}

reactor Parent {
  input inp: u32
  output out: u32
  f = new Foo()
}

reactor Child extends Parent {
  reaction(startup) -> f.inp {=
    ctx.set(f__inp, 42);
  =}

  reaction(f.out) {=
    println!("Out: {}", ctx.get(f__out).unwrap());
    if ctx.get(f__out).unwrap() != 42 {
        eprintln!("Expected 42");
        ctx.request_stop(Asap);
    }
  =}
}

main reactor {
  c = new Child()
}
