/**
 * Test a sender-receiver network system that relies on microsteps being taken into account. The
 * purpose of this test is to check whether the functionalities pertinent to dynamic maxwait
 * adjustments are present and functioning to a degree.
 *
 * This version of the test does not use a centralized coordinator to advance tag. Therefore, the
 * receiver will rely on an maxwait (initially zero) to wait long enough for messages to arrive
 * before advancing its tag. In this test, the maxwait is initially zero and gradually raised every
 * time an STP violation is perceived until no STP violation is observed. Therefore, the exact
 * outcome of the test will depend on actual runtime timing.
 *
 * @author Soroush Bateni
 */
target Python {
  timeout: 1 sec,
  coordination: decentralized
}

import Sender from "../lib/LoopedActionSender.lf"
import Receiver from "DistributedLoopedAction.lf"

reactor MaxwaitReceiver(take_a_break_after=10, break_interval = 400 msec) {
  input inp
  state last_time_updated_maxwait = 0
  r = new Receiver(take_a_break_after=10, break_interval = 400 msec)
  timer t(0, 1 msec)  # Force advancement of logical time

  reaction(inp) -> r.inp {=
    print(f"Received {inp.value}.")
    r.inp.set(inp.value)
  =} tardy {=
    print(f"Received {inp.value} late.")
    current_tag = lf.tag()
    print(f"STP violation of "
      f"({current_tag.time - inp.intended_tag.time}, "
      f"{current_tag.microstep - inp.intended_tag.microstep}) "
      "perceived on the input.")
    r.inp.set(inp.value)
    # Only update the STP offset once per
    # time step.
    if current_tag.time != self.last_time_updated_maxwait :
      print(f"Raising the maxwait by {MSEC(10)}.")
      lf.set_fed_maxwait(lf.get_fed_maxwait() + MSEC(10))
      self.last_time_updated_maxwait = current_tag.time
  =}

  reaction(t) {=
    # Do nothing
  =}
}

federated reactor DistributedLoopedActionDecentralized {
  sender = new Sender(take_a_break_after=10, break_interval = 400 msec)
  @maxwait(0)
  maxwaitReceiver = new MaxwaitReceiver(take_a_break_after=10, break_interval = 400 msec)

  sender.out -> maxwaitReceiver.inp
}
